-- =============================================
-- Config File System
-- =============================================

local CONFIG_ROOT   = "Config"
local CONFIG_FOLDER = "Config/ChickChick"
local HttpService   = game:GetService("HttpService")

if not isfolder(CONFIG_ROOT)   then makefolder(CONFIG_ROOT) end
if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end

local configNameInput = ""
local selectedConfig  = nil
local configDropdown  = nil
local SavedFlags      = {}

local function getConfigList()
    local list = {}
    local ok, files = pcall(listfiles, CONFIG_FOLDER)
    if ok and files then
        for _, fp in ipairs(files) do
            local name = fp:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end
    return list
end

local function refreshConfigDropdown()
    if configDropdown then
        local list = getConfigList()
        configDropdown:Refresh(list, true)
        selectedConfig = nil
    end
end

-- Section: Config (ขวา)
local SectionCfg = TabSettings:Section({
    Title = "Config",
    Desc  = "Config System",
    Side  = "right",
})

SectionCfg:Input({
    Title       = "Config Name",
    Placeholder = "Enter Config Name",
    Callback    = function(text) configNameInput = text end,
})

SectionCfg:Button({
    Title    = "Create Config",
    Color    = Color3.fromRGB(57, 255, 20),
    Icon     = "plus-circle",
    Callback = function()
        local name = (configNameInput or ""):match("^%s*(.-)%s*$")
        if name == "" then
            WindUI:Notify({ Title = "Config", Content = "Please enter a config name", Duration = 3, Icon = "alert-circle" })
            return
        end
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then
            WindUI:Notify({ Title = "Config", Content = "Config already exists", Duration = 3, Icon = "alert-triangle" })
            return
        end
        local ok, _ = pcall(writefile, path, HttpService:JSONEncode(SavedFlags))
        if ok then
            WindUI:Notify({ Title = "Config", Content = "Config created successfully", Duration = 3, Icon = "check-circle" })
            refreshConfigDropdown()
        else
            WindUI:Notify({ Title = "Config", Content = "Failed to create config", Duration = 3, Icon = "alert-circle" })
        end
    end,
})

local initList = getConfigList()
configDropdown = SectionCfg:Dropdown({
    Title    = "Select Config",
    Values   = initList,
    Default  = initList[1] or "",
    Callback = function(value) selectedConfig = value end,
})

SectionCfg:Button({
    Title    = "Save Config",
    Color    = Color3.fromRGB(57, 255, 20),
    Icon     = "save",
    Callback = function()
        if not selectedConfig or selectedConfig == "" then
            WindUI:Notify({ Title = "Config", Content = "Please select a config first", Duration = 3, Icon = "alert-circle" })
            return
        end
        local ok, _ = pcall(writefile, CONFIG_FOLDER .. "/" .. selectedConfig .. ".json", HttpService:JSONEncode(SavedFlags))
        if ok then
            WindUI:Notify({ Title = "Config", Content = "Config saved successfully", Duration = 3, Icon = "check-circle" })
        else
            WindUI:Notify({ Title = "Config", Content = "Failed to save config", Duration = 3, Icon = "alert-circle" })
        end
    end,
})

SectionCfg:Button({
    Title    = "Load Config",
    Color    = Color3.fromRGB(24, 119, 242),
    Icon     = "folder-open",
    Callback = function()
        if not selectedConfig or selectedConfig == "" then
            WindUI:Notify({ Title = "Config", Content = "Please select a config first", Duration = 3, Icon = "alert-circle" })
            return
        end
        local path = CONFIG_FOLDER .. "/" .. selectedConfig .. ".json"
        if not isfile(path) then
            WindUI:Notify({ Title = "Config", Content = "Config file not found", Duration = 3, Icon = "alert-circle" })
            return
        end
        local okR, raw = pcall(readfile, path)
        if not okR then
            WindUI:Notify({ Title = "Config", Content = "Failed to read config", Duration = 3, Icon = "alert-circle" })
            return
        end
        local okD, data = pcall(HttpService.JSONDecode, HttpService, raw)
        if not okD or type(data) ~= "table" then
            WindUI:Notify({ Title = "Config", Content = "Invalid config format", Duration = 3, Icon = "alert-circle" })
            return
        end
        for k, v in pairs(data) do SavedFlags[k] = v end
        if data.Theme   then WindUI:SetTheme(data.Theme) end
        if data.Acrylic ~= nil then WindUI:ToggleAcrylic(data.Acrylic) end
        WindUI:Notify({ Title = "Config", Content = "Config loaded successfully", Duration = 3, Icon = "check-circle" })
    end,
})

SectionCfg:Button({
    Title    = "Delete Config",
    Icon     = "trash-2",
    Color    = Color3.fromRGB(220, 60, 60),
    Callback = function()
        if not selectedConfig or selectedConfig == "" then
            WindUI:Notify({ Title = "Config", Content = "Please select a config first", Duration = 3, Icon = "alert-circle" })
            return
        end
        local path = CONFIG_FOLDER .. "/" .. selectedConfig .. ".json"
        if not isfile(path) then
            WindUI:Notify({ Title = "Config", Content = "Config file not found", Duration = 3, Icon = "alert-circle" })
            return
        end
        local ok, _ = pcall(delfile, path)
        if ok then
            WindUI:Notify({ Title = "Config", Content = "Config deleted successfully", Duration = 3, Icon = "check-circle" })
            refreshConfigDropdown()
        else
            WindUI:Notify({ Title = "Config", Content = "Failed to delete config", Duration = 3, Icon = "alert-circle" })
        end
    end,
})

