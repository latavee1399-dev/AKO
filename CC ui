-- ── Walk Speed ───────────────────────────────

local walkEnabled = false
local walkSpeed   = 16
local walkConn, walkRespConn

local function applyWalkSpeed()
    local hum = getHum()
    if hum then hum.WalkSpeed = walkSpeed end
end

local function startWalkSpeed()
    if walkConn then walkConn:Disconnect() end
    walkConn = RunService.Heartbeat:Connect(function()
        if walkEnabled then applyWalkSpeed() end
    end)
    if walkRespConn then walkRespConn:Disconnect() end
    walkRespConn = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.1)
        if walkEnabled then applyWalkSpeed() end
    end)
end

local function stopWalkSpeed()
    if walkConn     then walkConn:Disconnect();     walkConn     = nil end
    if walkRespConn then walkRespConn:Disconnect(); walkRespConn = nil end
    local hum = getHum()
    if hum then hum.WalkSpeed = 16 end
end

