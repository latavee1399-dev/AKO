        Callback = function()
            if not selectedConfig or selectedConfig == "" then
                WindUI:Notify({ Title = "Config", Content = "Please select a config first", Duration = 3, Icon = "alert-circle" })
                return
            end
            local path = CONFIG_FOLDER .. "/" .. selectedConfig .. ".json"
            if not isfile(path) then
                WindUI:Notify({ Title = "Config", Content = "Config file not found", Duration = 3, Icon = "alert-circle" })
                return
            end
            local okR, raw = pcall(readfile, path)
            if not okR then
                WindUI:Notify({ Title = "Config", Content = "Failed to read config", Duration = 3, Icon = "alert-circle" })
                return
            end
            local okD, data = pcall(HttpService.JSONDecode, HttpService, raw)
            if not okD or type(data) ~= "table" then
                WindUI:Notify({ Title = "Config", Content = "Invalid config format", Duration = 3, Icon = "alert-circle" })
                return
            end
            for k, v in pairs(data) do SavedFlags[k] = v end
            if data.Theme   then WindUI:SetTheme(data.Theme) end
            if data.Acrylic ~= nil then WindUI:ToggleAcrylic(data.Acrylic) end
            WindUI:Notify({ Title = "Config", Content = "Config loaded successfully", Duration = 3, Icon = "check-circle" })
        end,
    })

