    local walkConn, walkRespConn

    local function applyWalkSpeed()
        local hum = getHum()
        if hum then hum.WalkSpeed = walkSpeed end
    end

    local function startWalkSpeed()
        if walkConn then walkConn:Disconnect() end
        walkConn = RunService.Heartbeat:Connect(function()
            if walkEnabled then applyWalkSpeed() end
        end)
        if walkRespConn then walkRespConn:Disconnect() end
        walkRespConn = LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.1)
            if walkEnabled then applyWalkSpeed() end
        end)
    end

    local function stopWalkSpeed()
        if walkConn     then walkConn:Disconnect();     walkConn     = nil end
        if walkRespConn then walkRespConn:Disconnect(); walkRespConn = nil end
        local hum = getHum()
        if hum then hum.WalkSpeed = 16 end
    end

    SectionMovement:Toggle({
        Title    = "Walk Speed",
        Icon = "zap",
        Value    = false,
        Callback = function(state)
            walkEnabled = state
            if state then startWalkSpeed() else stopWalkSpeed() end
        end,
    })

    SectionMovement:Slider({
        Title    = "Walk Speed Value",
        Value = {
            Min = 10,
            Max = 150,
            Default = 16
        },
        Step = 1,
        Callback = function(val)
            walkSpeed = val
            if walkEnabled then applyWalkSpeed() end
        end,
    })

    -- ── Fly ──────────────────────────────────────
    local flyEnabled = false
    local flySpeed   = 10
    local flyPart, flyConn, flyRespConn

    local function stopFly()
        flyEnabled = false
        if flyConn then flyConn:Disconnect(); flyConn = nil end
        if flyPart then flyPart:Destroy();    flyPart = nil end
        local hum = getHum()
        if hum then hum.PlatformStand = false end
    end

    local function startFly()
        local root = getRoot()
        local hum  = getHum()
        if not root or not hum then return end
        hum.PlatformStand = true
        flyPart = Instance.new("Part")
        flyPart.Size         = Vector3.new(1,1,1)
        flyPart.CanCollide   = false
        flyPart.Anchored     = true
        flyPart.Transparency = 1
        flyPart.Parent       = workspace
        local cam = workspace.CurrentCamera
        if flyConn then flyConn:Disconnect() end
        flyConn = RunService.Heartbeat:Connect(function()
            if not flyEnabled then return end
            local r = getRoot()
            if not r then stopFly(); return end
            flyPart.CFrame = r.CFrame
            local mv = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W)         then mv = mv + cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S)         then mv = mv - cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A)         then mv = mv - cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D)         then mv = mv + cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv = mv + Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv = mv - Vector3.new(0,1,0) end
            if mv.Magnitude > 0 then mv = mv.Unit end
            r.Velocity = mv * flySpeed
        end)
        if flyRespConn then flyRespConn:Disconnect() end
        flyRespConn = LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.2)
            if flyEnabled then startFly() end
        end)
    end

    SectionMovement:Toggle({
        Title    = "Fly",
