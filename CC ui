    if infJumpRespConn then infJumpRespConn:Disconnect(); infJumpRespConn = nil end
    if _G._gag2_infJumpConn then pcall(function() _G._gag2_infJumpConn:Disconnect() end); _G._gag2_infJumpConn = nil end
