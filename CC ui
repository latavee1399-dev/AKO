    -- Config File System
    local CONFIG_ROOT   = "Config"
    local CONFIG_FOLDER = "Config/ChickChick"

    if not isfolder(CONFIG_ROOT)   then makefolder(CONFIG_ROOT) end
    if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end

    local configNameInput = ""
    local selectedConfig  = nil
    local configDropdown  = nil
    local SavedFlags      = {}

    local function getConfigList()
        local list = {}
        local ok, files = pcall(listfiles, CONFIG_FOLDER)
        if ok and files then
            for _, fp in ipairs(files) do
                local name = fp:match("([^/\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
        return list
    end

    local function refreshConfigDropdown()
        if configDropdown then
            local list = getConfigList()
            configDropdown:Refresh(list, true)
            selectedConfig = nil
        end
    end

    -- Section: Config
    local SectionCfg = TabSettings:Section({
        Title = "Config",
        Desc  = "Config System",
        Icon  = "settings",
        Side  = "right",
    })

    SectionCfg:Input({
        Title       = "Config Name",
        Placeholder = "Enter Config Name",
        Callback    = function(text) configNameInput = text end,
    })

    SectionCfg:Button({
        Title    = "Create Config",
        Color    = Color3.fromRGB(57, 255, 20),
        Icon     = "plus-circle",
        Callback = function()
            local name = (configNameInput or ""):match("^%s*(.-)%s*$")
            if name == "" then
                WindUI:Notify({ Title = "Config", Content = "Please enter a config name", Duration = 3, Icon = "alert-circle" })
                return
            end
            local path = CONFIG_FOLDER .. "/" .. name .. ".json"
            if isfile(path) then
                WindUI:Notify({ Title = "Config", Content = "Config already exists", Duration = 3, Icon = "alert-triangle" })
                return
            end
            local ok, _ = pcall(writefile, path, HttpService:JSONEncode(SavedFlags))
            if ok then
                WindUI:Notify({ Title = "Config", Content = "Config created successfully", Duration = 3, Icon = "check-circle" })
                refreshConfigDropdown()
            else
                WindUI:Notify({ Title = "Config", Content = "Failed to create config", Duration = 3, Icon = "alert-circle" })
            end
